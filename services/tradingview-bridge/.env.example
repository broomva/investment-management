# TradingView Bridge environment variables.
# Copy to .env (which is gitignored) and fill in.

# REQUIRED. Must be "paper" for PR 1 — service exits 1 if "live".
TVBRIDGE_TRADING_MODE=paper

# REQUIRED. Shared secret that Pine Script alerts must include in the JSON body
# under the `secret` field. Generate with: `openssl rand -hex 32`.
TVBRIDGE_TV_WEBHOOK_SECRET=replace-me-with-openssl-rand-hex-32

# OPTIONAL. Comma-separated TradingView webhook source IPs. Defaults to TV's
# currently published IPs (verify at https://www.tradingview.com/support/solutions/43000529348/).
# TVBRIDGE_TV_ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7

# OPTIONAL. Rate limit per IP per minute. Default 60.
# TVBRIDGE_RATE_LIMIT_PER_MINUTE=60

# OPTIONAL. Logging level. Default INFO. One of DEBUG, INFO, WARNING, ERROR.
# TVBRIDGE_LOG_LEVEL=INFO

# OPTIONAL. Enable trusting X-Forwarded-For header. Set to "true" if running
# behind a reverse proxy / Cloudflare Tunnel. Default false.
# TVBRIDGE_TRUST_FORWARDED_FOR=false
